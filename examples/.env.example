# ─────────────────────────────────────────────────────────────────────────────
# Demo .env — for trying the LLM-powered Learn-Why trial against
# `vulnerable-routes.ts` and `secure-routes.ts`.
#
# To use:
#   cp examples/.env.example examples/.env
#   # paste in one key below, then from the project root:
#   git add examples/vulnerable-routes.ts
#   npx ./colosseum-cli --demo
#
# With a key set, the GAME OVER screen's "Learn Why" modal will show
# `CRAFTED BY CLAUDE` (or `CRAFTED BY GPT`) instead of `TEMPLATE TRIAL`,
# and the questions will be generated live from your actual vulnerabilities.
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=

# Or, if you'd rather use OpenAI:
# OPENAI_API_KEY=
