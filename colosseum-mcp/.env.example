# Neon API credentials
# Get your API key from: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=your_neon_api_key_here

# Your Neon project ID
# Found in your Neon project dashboard URL or settings
NEON_PROJECT_ID=your_neon_project_id_here

# Production database connection string (used as the base for shadow clone branching)
# Format: postgresql://user:password@host/dbname
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb
