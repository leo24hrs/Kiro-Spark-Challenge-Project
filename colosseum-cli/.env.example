# ─────────────────────────────────────────────────────────────────────────────
# Kiro Colosseum CLI — environment template
#
# Copy this file to `.env` in the directory where you run `npx colosseum`
# (your project root, not this folder). Every variable below is OPTIONAL —
# the CLI degrades gracefully:
#
#   • No LLM key       → Learn-Why MCQs use the hand-written template bank
#   • No Neon vars     → Arena runs in scripted DEMO MODE (no DB touched)
#
# The CLI never writes secrets, never logs them, and refuses to commit them.
# ─────────────────────────────────────────────────────────────────────────────


# ── Learn-Why LLM (pick ONE; Anthropic wins if both are set) ─────────────────

# Anthropic Claude — generates context-aware MCQs from your real vulnerabilities.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Default model is claude-haiku-4-5-20251001 (snappy: 8–15s per trial).
# For richer wording at the cost of latency (25–40s per trial):
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# Or for top quality (slower still):
# ANTHROPIC_MODEL=claude-opus-4-5-20251101

# OpenAI GPT — fallback LLM if no Anthropic key is set.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Override the default model (gpt-4o-mini) if needed.
# OPENAI_MODEL=gpt-4o


# ── Live arena (Neon shadow branching) ───────────────────────────────────────
# Leave these empty to run the arena in DEMO MODE (gladiators perform a
# scripted attack — no real DB connection is made). Fill them in to make the
# gladiators run actual probes against a disposable Neon branch of your DB.

# Postgres connection string for your project DB.
DATABASE_URL=

# Neon API key — used to create and destroy the shadow branch.
# Get one at https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=

# Neon project ID that owns the database the shadow branch will fork from.
NEON_PROJECT_ID=
