{
  "name": "colosseum",
  "version": "1.0.0",
  "description": "Sentient honeypot pre-push security gate for developers",
  "type": "module",
  "bin": {
    "colosseum": "./dist/index.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc && mkdir -p dist/web && cp src/web/*.html dist/web/ && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "open": "10.1.2",
    "pg": "8.13.3"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "22.13.10",
    "@types/pg": "8.11.11",
    "rimraf": "6.0.1",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  }
}
